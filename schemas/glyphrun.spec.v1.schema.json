{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://glyphrun.dev/schemas/glyphrun.spec.v1.schema.json",
  "title": "Glyphrun Spec v1",
  "type": "object",
  "required": ["version", "name", "intent", "target", "steps", "outcomes"],
  "properties": {
    "version": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "contractHash": { "type": "string" },
    "intent": { "type": "string", "minLength": 1 },
    "metadata": { "$ref": "#/$defs/metadata" },
    "redaction": { "$ref": "#/$defs/redaction" },
    "artifacts": { "$ref": "#/$defs/capturePolicy" },
    "imports": { "type": "array", "items": { "type": "string" } },
    "target": {
      "type": "object",
      "required": ["cmd"],
      "properties": {
        "cmd": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "cwd": { "type": "string" },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "timeoutMs": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "terminal": {
      "type": "object",
      "properties": {
        "cols": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "profile": { "enum": ["xterm-256color", "vt100", "ansi"] },
        "color": { "enum": ["auto", "always", "never"] },
        "alternateScreen": { "enum": ["auto", "require", "forbid"] }
      },
      "additionalProperties": false
    },
    "preconditions": {
      "type": "object",
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["run"],
            "properties": {
              "run": { "type": "string" },
              "cwd": { "type": "string" },
              "timeoutMs": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "steps": { "type": "array", "items": { "$ref": "#/$defs/step" } },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "verify"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "verify": { "$ref": "#/$defs/verify" },
          "timeoutMs": { "type": "integer", "minimum": 1 },
          "normalize": { "$ref": "#/$defs/normalize" }
        },
        "additionalProperties": false
      }
    },
    "normalize": { "$ref": "#/$defs/normalize" }
  },
  "additionalProperties": false,
  "$defs": {
    "metadata": {
      "type": "object",
      "properties": {
        "feature": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "priority": { "enum": ["low", "normal", "high", "critical"] },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "redaction": {
      "type": "object",
      "properties": {
        "values": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "headers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "capturePolicy": {
      "type": "object",
      "properties": {
        "snapshots":      { "enum": ["always", "on-failure", "never"] },
        "frames":         { "enum": ["always", "on-failure", "never"] },
        "rawLog":         { "enum": ["always", "on-failure", "never"] },
        "finalScreen":    { "enum": ["always", "on-failure", "never"] },
        "agentContext":   { "enum": ["always", "on-failure", "never"] },
        "namedArtifacts": { "enum": ["always", "on-failure", "never"] },
        "screenshots":    { "enum": ["always", "on-failure", "never"] },
        "console":        { "enum": ["always", "on-failure", "never"] },
        "network":        { "enum": ["always", "on-failure", "never"] },
        "trace":          { "enum": ["always", "on-failure", "never"] },
        "storage":        { "enum": ["always", "on-failure", "never"] }
      },
      "additionalProperties": false
    },
    "normalize": {
      "type": "object",
      "properties": {
        "trimRight": { "type": "boolean" },
        "normalizeLineEndings": { "type": "boolean" },
        "stripAnsiTitle": { "type": "boolean" },
        "replace": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["regex", "with"],
            "properties": {
              "regex": { "type": "string" },
              "with": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "ignoreRegions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["x", "y", "width", "height"],
            "properties": {
              "x": { "type": "integer" },
              "y": { "type": "integer" },
              "width": { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "oneOf": [
        { "required": ["press"] },
        { "required": ["type"] },
        { "required": ["paste"] },
        { "required": ["send"] },
        { "required": ["wait"] },
        { "required": ["resize"] },
        { "required": ["snapshot"] },
        { "required": ["use"] },
        { "required": ["download"] },
        { "required": ["transform"] },
        { "required": ["batch"] }
      ],
      "properties": {
        "when": { "$ref": "#/$defs/verify" },
        "press": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "paste": { "type": "string", "minLength": 1 },
        "send": {
          "type": "object",
          "required": ["bytes"],
          "properties": {
            "bytes": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "wait": { "$ref": "#/$defs/wait" },
        "resize": {
          "type": "object",
          "required": ["cols", "rows"],
          "properties": {
            "cols": { "type": "integer", "minimum": 1 },
            "rows": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "snapshot": { "type": "string", "minLength": 1 },
        "use": { "type": "string", "minLength": 1 },
        "download": { "$ref": "#/$defs/download" },
        "transform": { "$ref": "#/$defs/transform" },
        "batch": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/batchSubStep" }
        }
      },
      "additionalProperties": false
    },
    "download": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "saveAs": { "type": "string", "minLength": 1 },
        "assign": {
          "type": "string",
          "pattern": "^[a-z][A-Za-z0-9_]*$"
        },
        "waitFor": { "type": "boolean" },
        "timeoutMs": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "transform": {
      "type": "object",
      "required": ["file", "saveAs"],
      "properties": {
        "runtime": { "enum": ["node", "shell"] },
        "file": { "type": "string", "minLength": 1 },
        "input": { "type": "string" },
        "saveAs": { "type": "string", "minLength": 1 },
        "assign": {
          "type": "string",
          "pattern": "^[a-z][A-Za-z0-9_]*$"
        },
        "fixtures": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "timeoutMs": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "batchSubStep": {
      "type": "object",
      "oneOf": [
        { "required": ["press"] },
        { "required": ["type"] },
        { "required": ["paste"] },
        { "required": ["send"] },
        { "required": ["wait"] }
      ],
      "properties": {
        "press": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "paste": { "type": "string", "minLength": 1 },
        "send": {
          "type": "object",
          "required": ["bytes"],
          "properties": {
            "bytes": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "wait": { "$ref": "#/$defs/wait" }
      },
      "additionalProperties": false
    },
    "wait": {
      "type": "object",
      "oneOf": [
        { "required": ["screen"] },
        { "required": ["process"] },
        { "required": ["idle"] }
      ],
      "properties": {
        "screen": { "$ref": "#/$defs/screenCondition" },
        "process": { "$ref": "#/$defs/processCondition" },
        "idle": {
          "type": "object",
          "required": ["quietForMs"],
          "properties": {
            "quietForMs": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "timeoutMs": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "verify": {
      "type": "object",
      "oneOf": [
        { "required": ["screen"] },
        { "required": ["region"] },
        { "required": ["cell"] },
        { "required": ["cursor"] },
        { "required": ["process"] },
        { "required": ["snapshot"] },
        { "required": ["command"] },
        { "required": ["file"] },
        { "required": ["script"] },
        { "required": ["count"] }
      ],
      "properties": {
        "screen": { "$ref": "#/$defs/screenCondition" },
        "region": { "$ref": "#/$defs/regionCondition" },
        "cell": { "$ref": "#/$defs/cellCondition" },
        "cursor": { "$ref": "#/$defs/cursorCondition" },
        "process": { "$ref": "#/$defs/processCondition" },
        "snapshot": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "mode": { "enum": ["text", "cell", "json"] },
            "normalize": { "$ref": "#/$defs/normalize" }
          },
          "additionalProperties": false
        },
        "command": {
          "type": "object",
          "required": ["run"],
          "properties": {
            "run": { "type": "string", "minLength": 1 },
            "cwd": { "type": "string" },
            "timeoutMs": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "file": {
          "type": "object",
          "required": ["glob"],
          "properties": {
            "glob": { "type": "string", "minLength": 1 },
            "contains": { "type": "string" },
            "timeoutMs": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "script": {
          "type": "object",
          "oneOf": [
            { "required": ["run"] },
            { "required": ["file"] }
          ],
          "properties": {
            "runtime": { "enum": ["node", "shell"] },
            "run": { "type": "string" },
            "file": { "type": "string" },
            "fixtures": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "timeoutMs": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "count": {
          "type": "object",
          "oneOf": [
            { "required": ["equals"] },
            { "required": ["atLeast"] },
            { "required": ["atMost"] },
            { "required": ["between"] }
          ],
          "properties": {
            "region": {
              "type": "object",
              "required": ["x", "y", "width", "height"],
              "properties": {
                "x": { "type": "integer", "minimum": 0 },
                "y": { "type": "integer", "minimum": 0 },
                "width": { "type": "integer", "minimum": 1 },
                "height": { "type": "integer", "minimum": 1 }
              },
              "additionalProperties": false
            },
            "matches": { "type": "string" },
            "equals": { "type": "integer", "minimum": 0 },
            "atLeast": { "type": "integer", "minimum": 0 },
            "atMost": { "type": "integer", "minimum": 0 },
            "between": {
              "type": "array",
              "items": { "type": "integer", "minimum": 0 },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "screenCondition": {
      "type": "object",
      "oneOf": [
        { "required": ["contains"] },
        { "required": ["notContains"] },
        { "required": ["regex"] }
      ],
      "properties": {
        "contains": { "type": "string", "minLength": 1 },
        "notContains": { "type": "string", "minLength": 1 },
        "regex": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "regionCondition": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "oneOf": [
        { "required": ["contains"] },
        { "required": ["notContains"] },
        { "required": ["regex"] }
      ],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "contains": { "type": "string", "minLength": 1 },
        "notContains": { "type": "string", "minLength": 1 },
        "regex": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "cellCondition": {
      "type": "object",
      "required": ["x", "y"],
      "anyOf": [
        { "required": ["char"] },
        { "required": ["style"] }
      ],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "char": { "type": "string", "minLength": 1 },
        "style": { "$ref": "#/$defs/styleCondition" }
      },
      "additionalProperties": false
    },
    "styleCondition": {
      "type": "object",
      "anyOf": [
        { "required": ["fg"] },
        { "required": ["bg"] },
        { "required": ["bold"] },
        { "required": ["dim"] },
        { "required": ["italic"] },
        { "required": ["underline"] },
        { "required": ["reverse"] }
      ],
      "properties": {
        "fg": { "type": "string", "minLength": 1 },
        "bg": { "type": "string", "minLength": 1 },
        "bold": { "type": "boolean" },
        "dim": { "type": "boolean" },
        "italic": { "type": "boolean" },
        "underline": { "type": "boolean" },
        "reverse": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "cursorCondition": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "visible": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "processCondition": {
      "type": "object",
      "oneOf": [
        { "required": ["exitCode"] },
        { "required": ["exited"] }
      ],
      "properties": {
        "exitCode": { "type": "integer" },
        "exited": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
