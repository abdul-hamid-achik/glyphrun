{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://glyphrun.dev/schemas/glyphrun.config.v1.schema.json",
  "title": "Glyphrun Config v1",
  "type": "object",
  "properties": {
    "version": { "const": 1 },
    "defaultEnvironment": { "type": "string", "minLength": 1 },
    "artifactRoot": { "type": "string", "minLength": 1 },
    "snapshotRoot": { "type": "string", "minLength": 1 },
    "schemaRoot": { "type": "string", "minLength": 1 },
    "environments": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/environment" }
    },
    "terminal": { "$ref": "#/$defs/terminal" },
    "artifacts": { "$ref": "#/$defs/artifacts" },
    "redaction": { "$ref": "#/$defs/redaction" },
    "retention": { "$ref": "#/$defs/retention" }
  },
  "additionalProperties": false,
  "$defs": {
    "environment": {
      "type": "object",
      "properties": {
        "vars": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "secrets": { "$ref": "#/$defs/secrets" }
      },
      "additionalProperties": false
    },
    "secrets": {
      "type": "object",
      "description": "Declare a tvault env-group (or direct project) whose resolved secrets are injected into the run environment at start time. The config carries only group/env/project names — never secret values.",
      "properties": {
        "provider": { "type": "string", "enum": ["tvault"], "default": "tvault" },
        "binary": { "type": "string", "minLength": 1, "description": "Path to the tvault executable (defaults to 'tvault' on PATH)" },
        "group": { "type": "string", "minLength": 1, "description": "tvault environment group name" },
        "env": { "type": "string", "minLength": 1, "description": "Environment name within the group" },
        "project": { "type": "string", "minLength": 1, "description": "Direct tvault project name (mutually exclusive with group+env)" },
        "only": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Allowlist of secret keys to inject (least privilege)"
        },
        "prefix": { "type": "string", "minLength": 1, "description": "Inject only keys with this prefix" }
      },
      "additionalProperties": false,
      "anyOf": [
        { "required": ["group", "env"] },
        { "required": ["project"] }
      ]
    },
    "terminal": {
      "type": "object",
      "properties": {
        "profile": { "enum": ["xterm-256color", "vt100", "ansi"] },
        "cols": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "normalize": { "$ref": "#/$defs/normalize" }
      },
      "additionalProperties": false
    },
    "normalize": {
      "type": "object",
      "properties": {
        "trimRight": { "type": "boolean" },
        "normalizeLineEndings": { "type": "boolean" },
        "hideCursorInTextSnapshots": { "type": "boolean" },
        "stripAnsiTitle": { "type": "boolean" },
        "ignoreCursorVisibility": { "type": "boolean" },
        "replace": {
          "type": "array",
          "items": { "$ref": "#/$defs/normalizeReplace" }
        },
        "ignoreRegions": {
          "type": "array",
          "items": { "$ref": "#/$defs/normalizeIgnoreRegion" }
        }
      },
      "additionalProperties": false
    },
    "normalizeReplace": {
      "type": "object",
      "required": ["regex", "with"],
      "properties": {
        "regex": { "type": "string", "minLength": 1 },
        "with": { "type": "string" }
      },
      "additionalProperties": false
    },
    "normalizeIgnoreRegion": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "rawLog": { "type": "boolean" },
        "frames": { "type": "boolean" },
        "finalScreen": { "type": "boolean" },
        "snapshots": { "type": "boolean" },
        "agentContext": { "type": "boolean" },
        "maxRawLogBytes": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "redaction": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "envAllowlist": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "patterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/redactionPattern" }
        }
      },
      "additionalProperties": false
    },
    "retention": {
      "type": "object",
      "properties": {
        "keepRuns": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "redactionPattern": {
      "type": "object",
      "required": ["name", "regex", "replace"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "regex": { "type": "string", "minLength": 1 },
        "replace": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
